# Security + caching headers — docs/09 §2-4 is authoritative.
# Honoured by Cloudflare Workers Static Assets. Astro copies public/ into dist/
# verbatim, then scripts/inject-csp-hash.ts rewrites <TT_GATE_HASH> below.
#
# Rules are applied most-specific-last, so the /* block comes first.

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-<TT_GATE_HASH>' https://www.youtube.com https://www.youtube-nocookie.com; frame-src https://www.youtube-nocookie.com https://www.youtube.com; img-src 'self' data: blob: https://i.ytimg.com; media-src 'self' blob:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; object-src 'none'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), midi=()
  Cross-Origin-Opener-Policy: same-origin
  X-Frame-Options: DENY
  Cache-Control: public, max-age=0, must-revalidate

# Hashed filenames — safe to cache forever (docs/09 §3).
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Not content-hashed, but the vendored font is pinned to a release and only
# changes when PROVENANCE.md does (docs/09 §3).
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
