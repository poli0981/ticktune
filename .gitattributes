# Windows dev box, Linux CI — normalise in the repo, check out native.
* text=auto eol=lf

# Binary assets: never munged, never diffed as text.
*.woff2 binary
*.woff  binary
*.ttf   binary
*.otf   binary
*.mp3   binary
*.flac  binary
*.opus  binary
*.ogg   binary
*.oga   binary
*.m4a   binary
*.wav   binary
*.webm  binary
*.png   binary
*.jpg   binary
*.ico   binary

# Vendored third-party files: stored exactly as released, no EOL normalisation.
# The woff2 is already covered by the binary rule above, but the licence text is
# not — and `* text=auto eol=lf` silently rewrote its CRLF endings, so the bytes
# shipped no longer matched what upstream published.
# See public/fonts/dseg7/PROVENANCE.md.
public/fonts/dseg7/** -text

# Generated — collapse in PR diffs.
pnpm-lock.yaml linguist-generated=true -diff
