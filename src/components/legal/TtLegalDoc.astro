---
import TtBase from '../../layouts/TtBase.astro';
import type { StaticDict } from '../../i18n/static/en';
import { TT_LEGAL_VERSION, ttLegalHref, type TtLegalKey } from '../../lib/tt-legal-const';

/**
 * A legal document page — P6 slice B, `docs/03 §3`, `docs/08 §1`.
 *
 * All eight routes render this: the four documents × two languages. The body
 * arrives through the default **slot** as the page's `<Content />`, already
 * compiled from markdown to static HTML at build time by the content collection
 * (`src/content.config.ts` explains why that is outside the `{@html}` ban). A
 * slot rather than a `Content` prop because the page is what owns the entry
 * lookup, and a component passed as a prop reads like a value.
 *
 * The banner is the load-bearing part. `docs/08 §1` says English is canonical
 * for interpretation, and a translated legal document that does not say so is a
 * translated legal document that claims to be authoritative. Both languages get
 * a banner — the EN one states it *is* canonical, the VI one states it is not —
 * because a banner only on the translation reads as a disclaimer rather than as
 * a statement of which text governs.
 */

interface Props {
  t: StaticDict;
  lang: 'vi' | 'en';
  docKey: TtLegalKey;
}

const { t, lang, docKey } = Astro.props;

const title = t.legal.docs[docKey];
const isCanonical = lang === 'en';

/**
 * The reciprocal pair for this document, built here so it cannot be
 * half-updated — the same reasoning as `TtLanding.astro`'s. `x-default` is the
 * Vietnamese route because Vietnamese is the site default (`docs/08 §1`).
 */
const viHref = ttLegalHref(docKey, 'vi');
const enHref = ttLegalHref(docKey, 'en');
const alternates = [
  { hreflang: 'vi', href: new URL(viHref, Astro.site).href },
  { hreflang: 'en', href: new URL(enHref, Astro.site).href },
  { hreflang: 'x-default', href: new URL(viHref, Astro.site).href },
];

const otherHref = lang === 'vi' ? enHref : viHref;
const otherLang = lang === 'vi' ? 'en' : 'vi';
const home = lang === 'vi' ? '/' : '/en/';
---

<TtBase title={`${title} — TickTune`} description={t.landing.description} {lang} {alternates}>
  <main class="tt-page">
    <nav class="tt-legal-nav" aria-label={t.common.switchToLabel}>
      <a href={home}>{t.common.backHome}</a>
      <a href={otherHref} hreflang={otherLang} lang={otherLang}>{t.common.switchTo}</a>
    </nav>

    <p class="tt-canonical" data-testid="tt-legal-canonical">
      {isCanonical ? t.legal.canonicalEn : t.legal.canonicalVi}
    </p>

    <article class="tt-prose">
      <slot />
    </article>

    <p class="tt-version" data-testid="tt-legal-version">
      {t.legal.versionLabel}
      {TT_LEGAL_VERSION}
    </p>
  </main>
</TtBase>

<style>
  .tt-page {
    width: min(48rem, 100% - 3rem);
    margin-inline: auto;
    padding-bottom: 4rem;
  }
  .tt-legal-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.25rem;
    font-size: 0.78rem;
  }
  .tt-legal-nav a {
    color: var(--color-tt-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .tt-legal-nav a:hover {
    color: var(--color-tt-text);
  }

  /* Not a warning colour: this states which text governs, it does not warn. */
  .tt-canonical {
    margin-bottom: 2rem;
    border-left: 2px solid var(--color-tt-signal);
    padding: 0.65rem 0.9rem;
    background: var(--color-tt-surface);
    color: var(--color-tt-muted);
    font-size: 0.8rem;
  }

  .tt-version {
    margin-top: 2.5rem;
    border-top: 1px solid var(--color-tt-line);
    padding-top: 1rem;
    color: var(--color-tt-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  /*
    Prose styles for the rendered markdown. Hand-written rather than pulling in
    @tailwindcss/typography: this is the only markdown surface in the project,
    and a distributed dependency would need a GPL-3.0 check and a notices row
    (docs/11 §5) to style four documents.

    `:global` is required — the body is generated by the markdown compiler, so
    Astro's scoping attribute never reaches it.
  */
  .tt-prose :global(h1) {
    margin-bottom: 1.5rem;
    font-size: 1.7rem;
    line-height: 1.25;
    text-wrap: balance;
  }
  .tt-prose :global(h2) {
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
    color: var(--color-tt-signal);
  }
  .tt-prose :global(p),
  .tt-prose :global(li) {
    margin-bottom: 0.9rem;
    line-height: 1.7;
  }
  .tt-prose :global(ul),
  .tt-prose :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.4rem;
  }
  .tt-prose :global(ol) {
    list-style: decimal;
  }
  .tt-prose :global(ul) {
    list-style: disc;
  }
  .tt-prose :global(a) {
    color: var(--color-tt-signal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .tt-prose :global(code) {
    padding: 0.1em 0.35em;
    border-radius: 3px;
    background: var(--color-tt-surface);
    font-family: var(--font-mono);
    font-size: 0.85em;
  }
  .tt-prose :global(strong) {
    color: var(--color-tt-text);
    font-weight: 600;
  }

  /*
    THIRD-PARTY-NOTICES is a wide table of licences. It scrolls in its own box
    rather than widening the page — the same rule the countdown rails follow.
  */
  .tt-prose :global(table) {
    display: block;
    width: 100%;
    margin-bottom: 1.25rem;
    overflow-x: auto;
    border-collapse: collapse;
    font-size: 0.82rem;
  }
  .tt-prose :global(th),
  .tt-prose :global(td) {
    border: 1px solid var(--color-tt-line);
    padding: 0.4rem 0.6rem;
    text-align: left;
    vertical-align: top;
  }
  .tt-prose :global(th) {
    background: var(--color-tt-surface);
    color: var(--color-tt-text);
  }
</style>
