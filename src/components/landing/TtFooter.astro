---
import type { StaticDict } from '../../i18n/static/en';
import { TT_LEGAL_LINKS, ttLegalHref } from '../../lib/tt-legal-const';

/**
 * Landing footer — legal links + the GPL-3.0 source offer.
 *
 * ⚠️ The source-offer link is not decoration. It has been on the page since the
 * very first deploy because **GPL-3.0 §6** requires the hosted build to offer
 * its corresponding source, and `src/pages/index.astro`'s original stub carried
 * a comment saying the real landing must keep it in the footer. Do not remove it.
 *
 * 🔴 **`lang` is not decoration.** P6 slice B pointed `TT_LEGAL_LINKS` at on-site
 * routes, and those constants are the **Vietnamese** ones. This component is the
 * only one of the three legal-link call sites that cannot read `i18n.lang` —
 * there is no runtime here, so the language has to be handed down from the page.
 * Read the constant directly and the VI footer keeps working by accident while
 * the EN footer links every document to its Vietnamese version: four valid URLs,
 * four 200s, all four wrong. `tests/e2e/legal.spec.ts` asserts the EN footer for
 * exactly this reason.
 */

interface Props {
  t: StaticDict['landing'];
  common: StaticDict['common'];
  legal: StaticDict['legal'];
  lang: 'vi' | 'en';
}

const { t, common, legal, lang } = Astro.props;

const docs = [
  { href: ttLegalHref('eula', lang), label: legal.docs.eula },
  { href: ttLegalHref('disclaimer', lang), label: legal.docs.disclaimer },
  { href: ttLegalHref('privacy', lang), label: legal.docs.privacy },
  { href: ttLegalHref('thirdParty', lang), label: legal.docs.thirdParty },
];
---

<footer class="tt-footer" aria-labelledby="tt-legal">
  <h2 id="tt-legal">{t.legalTitle}</h2>

  <ul>
    {
      docs.map((d) => (
        <li>
          <a href={d.href} rel="noopener noreferrer">
            {d.label}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="tt-note">{t.legalNote}</p>

  <p class="tt-source">
    <a href={TT_LEGAL_LINKS.repo} rel="noopener noreferrer">{common.sourceOffer}</a>
  </p>
</footer>

<style>
  .tt-footer {
    padding: 2.5rem 0 4rem;
    border-top: 1px solid var(--color-tt-line);
  }
  h2 {
    margin-bottom: 1rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-tt-muted);
  }
  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 1.1rem;
    list-style: none;
    padding: 0;
    font-size: 0.85rem;
  }
  a {
    color: var(--color-tt-signal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .tt-note {
    margin-top: 0.9rem;
    font-size: 0.75rem;
    color: var(--color-tt-muted);
  }
  .tt-source {
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }
  .tt-source a {
    color: var(--color-tt-muted);
  }
  .tt-source a:hover {
    color: var(--color-tt-text);
  }
</style>
