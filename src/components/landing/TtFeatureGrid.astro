---
import type { StaticDict } from '../../i18n/static/en';

/** Landing feature grid — docs/03 §3 item 1. Static, zero JS. */

interface Props {
  t: StaticDict['landing'];
}

const { t } = Astro.props;
---

<section class="tt-section" aria-labelledby="tt-features">
  <h2 id="tt-features">{t.featuresTitle}</h2>
  <ul class="tt-grid">
    {
      t.features.map((f) => (
        <li>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .tt-section {
    padding: 2.5rem 0;
  }
  h2 {
    margin-bottom: 1.25rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-tt-muted);
  }
  .tt-grid {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
  }
  @media (min-width: 48rem) {
    .tt-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  li {
    padding: 1.1rem;
    background: color-mix(in srgb, var(--color-tt-surface) 70%, transparent);
    border: 1px solid var(--color-tt-line);
    border-radius: 0.5rem;
  }
  h3 {
    margin-bottom: 0.45rem;
    font-size: 0.95rem;
    color: var(--color-tt-text);
  }
  p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-tt-muted);
    text-wrap: pretty;
  }
</style>
