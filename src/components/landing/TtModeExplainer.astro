---
import type { StaticDict } from '../../i18n/static/en';

/**
 * Mode explainer — docs/03 §3 item 1, the three modes of docs/02 §1.
 *
 * The closing note states docs/06 §5's "sources do not mix" rule, because that
 * is the one thing about the modes people discover by being refused.
 */

interface Props {
  t: StaticDict['landing'];
}

const { t } = Astro.props;
---

<section class="tt-section" aria-labelledby="tt-modes">
  <h2 id="tt-modes">{t.modesTitle}</h2>
  <ul class="tt-grid">
    {
      t.modes.map((m) => (
        <li>
          <h3>{m.name}</h3>
          <p>{m.body}</p>
        </li>
      ))
    }
  </ul>
  <p class="tt-note">{t.modesNote}</p>
</section>

<style>
  .tt-section {
    padding: 2.5rem 0;
  }
  h2 {
    margin-bottom: 1.25rem;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-tt-muted);
  }
  .tt-grid {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
  }
  @media (min-width: 48rem) {
    .tt-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  li {
    padding: 1.1rem;
    background: color-mix(in srgb, var(--color-tt-surface) 70%, transparent);
    border: 1px solid var(--color-tt-line);
    border-radius: 0.5rem;
  }
  h3 {
    margin-bottom: 0.45rem;
    font-size: 0.95rem;
    color: var(--color-tt-signal);
  }
  p {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-tt-muted);
    text-wrap: pretty;
  }
  .tt-note {
    margin-top: 1rem;
    font-size: 0.78rem;
  }
</style>
