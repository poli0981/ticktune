---
// VI — renders legal/vi/EULA.md via the legalVi collection.
// docs/08 §1: VI at the root, EN under /en/. The page owns the entry lookup;
// TtLegalDoc owns everything around the body.
import { getEntry, render } from 'astro:content';
import TtLegalDoc from '../../components/legal/TtLegalDoc.astro';
import { vi } from '../../i18n/static/vi';

const entry = await getEntry('legalVi', 'eula');
if (!entry) throw new Error('Missing legalVi entry: eula');
const { Content } = await render(entry);
---

<TtLegalDoc t={vi} lang="vi" docKey="eula">
  <Content />
</TtLegalDoc>
